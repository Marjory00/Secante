############################
# 🔒 PRIVATE BUSINESS LOGIC
############################
# 🚨 
# Hide proprietary logic

backend/app/private/
backend/app/internal/
backend/app/proprietary/

# Example: sensitive algorithms
backend/app/services/secret_engine.py
backend/app/services/risk_model.py

# Example: internal APIs
backend/app/api/internal/

############################
# 🔐 PARTIAL FILE PROTECTION (IMPORTANT)
############################
# If a file has both public + private logic,
# move private parts to:
# backend/app/private/

############################
# 📁 OPTIONAL: PRIVATE FRONTEND LOGIC
############################
frontend/src/private/
frontend/src/internal/

